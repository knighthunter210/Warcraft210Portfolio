local QuestDefinitions = require(game.ServerScriptService.Data.QuestDefinitions)

local DailyQuests = table.clone(QuestDefinitions:GetSection("Daily") or {})
DailyQuests.All = DailyQuests.Definitions or {}

function DailyQuests:GetRandomSet(count)
	local pool = table.clone(self.All)
	local chosen = {}
	for _ = 1, count do
		if #pool == 0 then
			break
		end
		local index = math.random(1, #pool)
		table.insert(chosen, table.remove(pool, index))
	end
	return chosen
end

return DailyQuests
