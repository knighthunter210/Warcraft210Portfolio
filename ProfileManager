function ProfileManager:AddGauntlentToInventory(Player, Gauntlent, Rarity)
	local Profile = Profiles[Player]
	if not Profile then return end
	if table.find(Profile.Data.OwnedGauntlents, Gauntlent) then
		if Rarity == "Common" then
			ProfileManager:AddMoney(Player, 50)
		elseif Rarity == "Uncommon" then
			ProfileManager:AddMoney(Player, 100)
		elseif Rarity == "Rare" then
			ProfileManager:AddMoney(Player, 250)
		elseif Rarity == "Epic" then
			ProfileManager:AddMoney(Player, 500)
		elseif Rarity == "Legendary" then
			ProfileManager:AddMoney(Player, 1000)
		end
