function ProfileManager:PurchaseGlove(Player, ItemSection, ItemName)
	local sectionTable = ShopInfo[ItemSection]
	if not sectionTable then return end
	local ItemInfo = sectionTable[ItemName]
	if not ItemInfo then return end
	local moneyVal = Player:FindFirstChild("Money")
	if not moneyVal then return end
	if moneyVal.Value >= (ItemInfo.Price or 0) then
		local Profile = Profiles[Player]
		if not ItemInfo.Robux then
			Profile.Data.Money -= (ItemInfo.Price or 0)
		end
		if ItemSection == "Gauntlents" then
			table.insert(Profile.Data.OwnedGauntlents, ItemName)
		elseif ItemSection == "Abilities" then
			table.insert(Profile.Data.OwnedAbilities, ItemName)
		elseif ItemSection == "GrabAnimations" then
			table.insert(Profile.Data.OwnedGrabAnimations, ItemName)
		elseif ItemSection == "Titles" then
			table.insert(Profile.Data.OwnedTitles, ItemName)
		end
		Player.Money.Value = Profile.Data.Money
		local SV = Instance.new("StringValue", Player:FindFirstChild("Owned"..ItemSection))
		SV.Name = ItemName
		SV.Value = ItemName
		safeSave(Profile)
	end
end

function ProfileManager:EquipItem(Player, ItemSection, ItemName)
	local Profile = Profiles[Player]
	if not Profile then return end

	if ItemSection == "Gauntlents" then
		if table.find(Profile.Data.OwnedGauntlents, ItemName) then
			Profile.Data.EquippedGauntlent = ItemName
			Player.Equipped.EquippedGauntlent.Value = ItemName

			local Tools = {}
			for _, Child in pairs(Player.Backpack:GetChildren()) do
				if Child:IsA("Tool") then
					table.insert(Tools, Child)
				end
			end

			if not Player.Character then
				Player.CharacterAdded:Wait()
			end

			for _, Child in pairs(Player.Character:GetChildren()) do
				if Child:IsA("Tool") then
					table.insert(Tools, Child)
				end
			end

			for _, Tool in pairs(Tools) do
				if string.find(Tool.Name, "Gauntlent") then
					Tool:Destroy()
				end
			end

			local t = ServerStorage.GauntlentTools:FindFirstChild(ItemName)
			if t then
				t:Clone().Parent = Player.Backpack
			end

			Player.CharacterAdded:Connect(function(char)
				task.wait(0.3)
				local equipped = Player.Equipped and Player.Equipped:FindFirstChild("EquippedGauntlent")
				local item = equipped and equipped.Value
				if item and ServerStorage:FindFirstChild("GauntlentTools") then
					local tool = ServerStorage.GauntlentTools:FindFirstChild(item)
					if tool then
						tool:Clone().Parent = Player.Backpack
					end
				end
			end)
		end
	end
end

