local function alreadyCredited(character)
	return character:FindFirstChild("KillCredited") ~= nil
end

local function markCredited(character)
	if not alreadyCredited(character) then
		local creditedTag = Instance.new("BoolValue")
		creditedTag.Name = "KillCredited"
		creditedTag.Parent = character
		creditedTag:SetAttribute("Persistent", true)
	end
end

local function safeSave(profile)
	-- Disable saving if we are in Studio to prevent overwriting real data with test data
	if RunService:IsStudio() then return end

	if profile then
		local ok = pcall(function()
			profile:Save()
		end)
		if not ok then end
	end
end

local function isInLobby(character)
	if not character then return false end
	local root = character:FindFirstChild("HumanoidRootPart")
	if not root then return false end
	local rel = lobbyPart.CFrame:PointToObjectSpace(root.Position)
	return math.abs(rel.X) <= lobbyPart.Size.X/2 and math.abs(rel.Y) <= lobbyPart.Size.Y/2 and math.abs(rel.Z) <= lobbyPart.Size.Z/2
end

local function startAutoSave(player, profile)
	if RunService:IsStudio() then return end -- Don't autosave test data
	AutoSaveTasks[player] = task.spawn(function()
		while player.Parent == Players and Profiles[player] do
			task.wait(AUTOSAVE_INTERVAL)
			safeSave(profile)
		end
	end)
end

local function stopAutoSave(player)
	if AutoSaveTasks[player] then
		task.cancel(AutoSaveTasks[player])
		AutoSaveTasks[player] = nil
	end
end

local function syncHighestKillStreak(player, profile)
	if not profile then return end
	local current = profile.Data.KillStreak or 0
	local highest = profile.Data.HighestKillStreak or 0
	if current > highest then
		profile.Data.HighestKillStreak = current
	end
	StatsService:SyncStat(player, profile, "HighestKillStreak")
end

local function syncPositiveMoneyStats(player, profile, amount)
	if not profile or (amount or 0) <= 0 then
		return
	end
	profile.Data.TotalGSEarned = (profile.Data.TotalGSEarned or 0) + amount
	StatsService:SyncStat(player, profile, "G$Earned")
end

local function handleDeath(player, profile, character)
	if not profile or not character then return end
	if isInLobby(character) then
		safeSave(profile)
		return
	end
	if profile.Data.KillStreak >= 8 then
		profile.Data.LastLostStreak = profile.Data.KillStreak
		profile.Data.KillStreak = 0
		safeSave(profile)
		PromptRestoreStreak:FireClient(player, profile.Data.LastLostStreak)
	else
		profile.Data.KillStreak = 0
		safeSave(profile)
	end
	local ks = player:FindFirstChild("leaderstats") and player.leaderstats:FindFirstChild("KillStreak")
	if ks then
		ks.Value = profile.Data.KillStreak
	end
end

