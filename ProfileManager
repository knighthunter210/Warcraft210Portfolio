function ProfileManager:GiveMoney(player, amount, reason)
	local profile = Profiles[player]
	if not profile then
		warn("GiveMoney failed: No profile for", player)
		return false
	end

	if typeof(amount) ~= "number" then
		warn("GiveMoney failed: Invalid amount", amount)
		return false
	end

	-- Add money
	profile.Data.Money += amount
	syncPositiveMoneyStats(player, profile, amount)

	-- Update leaderstats
	local leaderstats = player:FindFirstChild("leaderstats")
	if leaderstats then
		local moneyStat = leaderstats:FindFirstChild("G$")
		if moneyStat then
			moneyStat.Value = profile.Data.Money
		end
	end

	-- Update player value (if exists)
	local moneyValue = player:FindFirstChild("Money")
	if moneyValue then
		moneyValue.Value = profile.Data.Money
	end

	-- Optional: reason logging (useful for debugging / analytics)
	if reason then
		print("[Money Added]", player.Name, "+", amount, "| Reason:", reason)
	end

	safeSave(profile)

	return true
end

function ProfileManager:GiveAbility(player, abilityName)
	local profile = Profiles[player]
	if not profile then
		warn("GiveAbility failed: No profile for", player)
		return false
	end
	
	if not table.find(profile.Data.OwnedAbilities, abilityName) then
		table.insert(profile.Data.OwnedAbilities, abilityName)
		
	else
		warn("GiveAbility failed: Already has ", abilityName, " for ", player)
		return true
	end
		local OwnedAbilities = player:WaitForChild("OwnedAbilities")
		if OwnedAbilities then
			print("Added ability to player:", abilityName)
			local newAbility = Instance.new("StringValue")
			newAbility.Name = abilityName
			newAbility.Value = abilityName
			newAbility.Parent = OwnedAbilities
		end
		safeSave(profile)
		return true
	
end

for _, plr in ipairs(Players:GetPlayers()) do
	task.spawn(PlayerAdded, plr)
end

game:BindToClose(function()
	for _, profile in pairs(Profiles) do
		safeSave(profile)
		profile:EndSession()
	end
end)

return ProfileManager
