function ProfileManager:AddKills(player, amt, victimName)
	local profile = Profiles[player]
	if not profile then return end
	victimName = victimName or "Unknown"
	local now = os.clock()
	profile.Data.Kills += amt
	-- Capture previous kill time BEFORE we overwrite it, so double-kill detection compares to the prior kill
	local prevKillTime = profile._lastKillTime
	if prevKillTime == nil then
		prevKillTime = now -- first-ever kill: use now so the streak window check is trivially true
	end
	if (now - prevKillTime) <= 10 then
		profile.Data.KillStreak += amt
	else
		if profile.Data.KillStreak < 1 then
			profile.Data.KillStreak = amt
		end
	end
	profile._lastKillTime = now
	safeSave(profile)
	local ls = player:FindFirstChild("leaderstats")
	if ls then
		local k = ls:FindFirstChild("Kills")
		local ks = ls:FindFirstChild("KillStreak")
		if k then k.Value = profile.Data.Kills end
		if ks then ks.Value = profile.Data.KillStreak end
	end
	StatsService:SyncStat(player, profile, "TotalKills")
	syncHighestKillStreak(player, profile)
	local baseReward = 5
	local streak = profile.Data.KillStreak
	local tier = math.clamp(streak, 1, 5)
	local reward = baseReward
	local rampageCount = 0
	if tier == 5 then
		reward += 5
		profile._rampageCount = (profile._rampageCount or 0) + 1
		rampageCount = profile._rampageCount
	else
		profile._rampageCount = 0
	end
	ProfileManager:AddMoney(player, reward)
	local remotes = game:GetService("ReplicatedStorage"):WaitForChild("Remotes")
	local PlaySFX2 = remotes:WaitForChild("PlaySFX")
	PlaySFX2:FireClient(player, "Kill" .. tostring(tier))
	local QuestServer = require(game.ServerScriptService.QuestServer)
	QuestServer.IncrementQuest(player, "Kills", amt)
	QuestServer.SetQuestMax(player, "KillStreak", streak)
	-- Double kill: only counts if there was a prior kill AND it happened within 3 seconds
	if prevKillTime ~= now and (now - prevKillTime) <= 3 then
		QuestServer.IncrementQuest(player, "DoubleKills", 1)
	end
end

