local QuestDefinitions = {}

local function buildIndex(definitions)
	local guaranteedIds = {}
	local definitionsById = {}

	for _, def in ipairs(definitions) do
		def.Reward = def.Reward or 150
		table.insert(guaranteedIds, def.ID)
		definitionsById[def.ID] = def
	end

	return guaranteedIds, definitionsById
end

