for sectionName, section in pairs(QuestDefinitions.Sections) do
	section.Name = sectionName
	section.GuaranteedIds, section.DefinitionsById = buildIndex(section.Definitions)
end

function QuestDefinitions:GetSection(sectionName)
	return self.Sections[sectionName]
end

function QuestDefinitions:GetSectionNames()
	return {"Daily", "Weekly", "Lifetime"}
end

function QuestDefinitions:BuildQuestFromDef(def)
	return {
		ID = def.ID,
		Description = def.Description,
		Goal = def.Goal,
		Stat = def.Stat,
		Reward = def.Reward or 150,
		DisplayDivisor = def.DisplayDivisor,
	}
end

return QuestDefinitions
